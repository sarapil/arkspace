 "html": "<style>\n\t.print-format {\n\t\tfont-family: 'Inter', 'Segoe UI', sans-serif;\n\t\tcolor: #1F2937;\n\t\tline-height: 1.6;\n\t}\n\t.rcpt-header {\n\t\tbackground: linear-gradient(135deg, #1B365D 0%, #2A4A7F 100%);\n\t\tcolor: #FFFFFF;\n\t\tpadding: 30px;\n\t\tborder-radius: 12px;\n\t\tmargin-bottom: 24px;\n\t\tposition: relative;\n\t}\n\t.rcpt-header::after {\n\t\tcontent: '';\n\t\tposition: absolute;\n\t\tbottom: 0;\n\t\tleft: 0;\n\t\twidth: 100%;\n\t\theight: 4px;\n\t\tbackground: linear-gradient(90deg, #C4A962 0%, #E8D5A0 50%, #C4A962 100%);\n\t}\n\t.rcpt-header h1 {\n\t\tmargin: 0 0 4px 0;\n\t\tfont-size: 22px;\n\t\tfont-weight: 700;\n\t}\n\t.rcpt-header .subtitle {\n\t\tfont-size: 13px;\n\t\topacity: 0.85;\n\t}\n\t.rcpt-header .doc-id {\n\t\tposition: absolute;\n\t\ttop: 30px;\n\t\tright: 30px;\n\t\tbackground: rgba(255,255,255,0.15);\n\t\tpadding: 6px 16px;\n\t\tborder-radius: 20px;\n\t\tfont-size: 13px;\n\t\tfont-weight: 600;\n\t}\n\t.rcpt-section {\n\t\tmargin-bottom: 20px;\n\t\tborder: 1px solid #E5E7EB;\n\t\tborder-radius: 10px;\n\t\toverflow: hidden;\n\t}\n\t.rcpt-section-title {\n\t\tbackground: #F8FAFC;\n\t\tpadding: 10px 20px;\n\t\tfont-size: 13px;\n\t\tfont-weight: 700;\n\t\tcolor: #1B365D;\n\t\ttext-transform: uppercase;\n\t\tletter-spacing: 0.5px;\n\t\tborder-bottom: 1px solid #E5E7EB;\n\t}\n\t.rcpt-section-body {\n\t\tpadding: 16px 20px;\n\t}\n\t.rcpt-row {\n\t\tdisplay: flex;\n\t\tjustify-content: space-between;\n\t\tpadding: 8px 0;\n\t\tborder-bottom: 1px solid #F1F5F9;\n\t}\n\t.rcpt-row:last-child { border-bottom: none; }\n\t.rcpt-label {\n\t\tcolor: #6B7280;\n\t\tfont-size: 13px;\n\t\tfont-weight: 500;\n\t}\n\t.rcpt-value {\n\t\tcolor: #1F2937;\n\t\tfont-size: 13px;\n\t\tfont-weight: 600;\n\t\ttext-align: right;\n\t}\n\t.rcpt-total {\n\t\tbackground: linear-gradient(135deg, #1B365D 0%, #2A4A7F 100%);\n\t\tcolor: #FFFFFF;\n\t\tpadding: 14px 20px;\n\t\tborder-radius: 8px;\n\t\tmargin-top: 16px;\n\t\tdisplay: flex;\n\t\tjustify-content: space-between;\n\t\talign-items: center;\n\t}\n\t.rcpt-total .amount {\n\t\tfont-size: 22px;\n\t\tfont-weight: 800;\n\t}\n\t.rcpt-plan-badge {\n\t\tdisplay: inline-block;\n\t\tbackground: linear-gradient(135deg, #C4A962 0%, #A38B4C 100%);\n\t\tcolor: #1B365D;\n\t\tpadding: 4px 14px;\n\t\tborder-radius: 16px;\n\t\tfont-size: 12px;\n\t\tfont-weight: 700;\n\t\tletter-spacing: 0.3px;\n\t}\n\t.rcpt-footer {\n\t\ttext-align: center;\n\t\tmargin-top: 30px;\n\t\tpadding-top: 20px;\n\t\tborder-top: 2px solid #E5E7EB;\n\t\tcolor: #9CA3AF;\n\t\tfont-size: 11px;\n\t}\n\t.rcpt-footer .brand {\n\t\tcolor: #C4A962;\n\t\tfont-weight: 700;\n\t\tfont-size: 13px;\n\t}\n</style>\n\n<div class=\"rcpt-header\">\n\t<h1>\u0625\u064a\u0635\u0627\u0644 \u0639\u0636\u0648\u064a\u0629 / Membership Receipt</h1>\n\t<div class=\"subtitle\">{{ doc.company or frappe.defaults.get_defaults().company or \"ARKSpace\" }}</div>\n\t<div class=\"doc-id\">{{ doc.name }}</div>\n</div>\n\n<div class=\"rcpt-section\">\n\t<div class=\"rcpt-section-title\">\ud83d\udc64 Member Details / \u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0639\u0636\u0648</div>\n\t<div class=\"rcpt-section-body\">\n\t\t<div class=\"rcpt-row\">\n\t\t\t<span class=\"rcpt-label\">{{ _(\"Member\") }}</span>\n\t\t\t<span class=\"rcpt-value\">{{ doc.member_name or doc.member }}</span>\n\t\t</div>\n\t\t<div class=\"rcpt-row\">\n\t\t\t<span class=\"rcpt-label\">{{ _(\"Membership Plan\") }}</span>\n\t\t\t<span class=\"rcpt-value\">\n\t\t\t\t<span class=\"rcpt-plan-badge\">{{ doc.membership_plan }}</span>\n\t\t\t</span>\n\t\t</div>\n\t\t<div class=\"rcpt-row\">\n\t\t\t<span class=\"rcpt-label\">{{ _(\"Plan Type\") }}</span>\n\t\t\t<span class=\"rcpt-value\">{{ _(doc.plan_type or '') }}</span>\n\t\t</div>\n\t</div>\n</div>\n\n<div class=\"rcpt-section\">\n\t<div class=\"rcpt-section-title\">\ud83d\udcc5 Period / \u0627\u0644\u0641\u062a\u0631\u0629</div>\n\t<div class=\"rcpt-section-body\">\n\t\t<div class=\"rcpt-row\">\n\t\t\t<span class=\"rcpt-label\">{{ _(\"Billing Cycle\") }}</span>\n\t\t\t<span class=\"rcpt-value\">{{ _(doc.billing_cycle) }}</span>\n\t\t</div>\n\t\t<div class=\"rcpt-row\">\n\t\t\t<span class=\"rcpt-label\">{{ _(\"Start Date\") }}</span>\n\t\t\t<span class=\"rcpt-value\">{{ doc.get_formatted(\"start_date\") }}</span>\n\t\t</div>\n\t\t<div class=\"rcpt-row\">\n\t\t\t<span class=\"rcpt-label\">{{ _(\"End Date\") }}</span>\n\t\t\t<span class=\"rcpt-value\">{{ doc.get_formatted(\"end_date\") }}</span>\n\t\t</div>\n\t\t<div class=\"rcpt-row\">\n\t\t\t<span class=\"rcpt-label\">{{ _(\"Auto Renew\") }}</span>\n\t\t\t<span class=\"rcpt-value\">{{ _(\"Yes\") if doc.auto_renew else _(\"No\") }}</span>\n\t\t</div>\n\t</div>\n</div>\n\n{% if doc.assigned_space or doc.branch %}\n<div class=\"rcpt-section\">\n\t<div class=\"rcpt-section-title\">\ud83c\udfe2 Assignment / \u0627\u0644\u062a\u0639\u064a\u064a\u0646</div>\n\t<div class=\"rcpt-section-body\">\n\t\t{% if doc.assigned_space %}\n\t\t<div class=\"rcpt-row\">\n\t\t\t<span class=\"rcpt-label\">{{ _(\"Assigned Space\") }}</span>\n\t\t\t<span class=\"rcpt-value\">{{ doc.assigned_space }}</span>\n\t\t</div>\n\t\t{% endif %}\n\t\t{% if doc.branch %}\n\t\t<div class=\"rcpt-row\">\n\t\t\t<span class=\"rcpt-label\">{{ _(\"Branch\") }}</span>\n\t\t\t<span class=\"rcpt-value\">{{ doc.branch }}</span>\n\t\t</div>\n\t\t{% endif %}\n\t</div>\n</div>\n{% endif %}\n\n<div class=\"rcpt-section\">\n\t<div class=\"rcpt-section-title\">\ud83d\udcb0 Billing / \u0627\u0644\u0641\u0648\u0627\u062a\u064a\u0631</div>\n\t<div class=\"rcpt-section-body\">\n\t\t<div class=\"rcpt-row\">\n\t\t\t<span class=\"rcpt-label\">{{ _(\"Rate\") }}</span>\n\t\t\t<span class=\"rcpt-value\">{{ doc.get_formatted(\"rate\") }}</span>\n\t\t</div>\n\t\t{% if doc.discount_percent %}\n\t\t<div class=\"rcpt-row\">\n\t\t\t<span class=\"rcpt-label\">{{ _(\"Discount\") }}</span>\n\t\t\t<span class=\"rcpt-value\" style=\"color: #10B981;\">{{ doc.discount_percent }}%</span>\n\t\t</div>\n\t\t{% endif %}\n\t\t{% if doc.setup_fee_charged %}\n\t\t<div class=\"rcpt-row\">\n\t\t\t<span class=\"rcpt-label\">{{ _(\"Setup Fee\") }}</span>\n\t\t\t<span class=\"rcpt-value\">{{ _(\"Charged\") }}</span>\n\t\t</div>\n\t\t{% endif %}\n\t</div>\n</div>\n\n<div class=\"rcpt-total\">\n\t<span style=\"font-size: 14px; font-weight: 600;\">{{ _(\"Net Amount\") }} / \u0627\u0644\u0645\u0628\u0644\u063a \u0627\u0644\u0635\u0627\u0641\u064a</span>\n\t<span class=\"amount\">{{ doc.get_formatted(\"net_amount\") }}</span>\n</div>\n\n{% if doc.initial_credits %}\n<div style=\"margin-top: 16px; padding: 12px 16px; background: #FFFBEB; border-radius: 8px; border: 1px solid #FDE68A;\">\n\t<span style=\"color: #92400E; font-weight: 600; font-size: 13px;\">&#9733; {{ _(\"Credits Included\") }}: {{ doc.initial_credits }}</span>\n</div>\n{% endif %}\n\n<div class=\"rcpt-footer\">\n\t<div class=\"brand\">ARKSpace</div>\n\t<div>{{ _(\"This is a computer-generated document. No signature is required.\") }}</div>\n\t<div>{{ frappe.utils.format_date(frappe.utils.now(), \"dd MMMM yyyy\") }}</div>\n</div>",
