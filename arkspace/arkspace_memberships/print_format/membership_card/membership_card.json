 "doctype": "Print Format",
 "html": "<style>\n\t.print-format {\n\t\tfont-family: 'Inter', 'Segoe UI', sans-serif;\n\t\tcolor: #1F2937;\n\t}\n\t.card-container {\n\t\twidth: 400px;\n\t\tmargin: 0 auto;\n\t\tborder-radius: 16px;\n\t\toverflow: hidden;\n\t\tbox-shadow: 0 4px 20px rgba(27, 54, 93, 0.2);\n\t}\n\t.card-top {\n\t\tbackground: linear-gradient(135deg, #1B365D 0%, #0F1D33 100%);\n\t\tcolor: #FFFFFF;\n\t\tpadding: 30px;\n\t\tposition: relative;\n\t\tmin-height: 140px;\n\t}\n\t.card-top::before {\n\t\tcontent: '';\n\t\tposition: absolute;\n\t\ttop: -30px;\n\t\tright: -30px;\n\t\twidth: 120px;\n\t\theight: 120px;\n\t\tborder-radius: 50%;\n\t\tbackground: rgba(196, 169, 98, 0.15);\n\t}\n\t.card-top::after {\n\t\tcontent: '';\n\t\tposition: absolute;\n\t\tbottom: -20px;\n\t\tleft: -20px;\n\t\twidth: 80px;\n\t\theight: 80px;\n\t\tborder-radius: 50%;\n\t\tbackground: rgba(196, 169, 98, 0.1);\n\t}\n\t.card-brand {\n\t\tfont-size: 11px;\n\t\ttext-transform: uppercase;\n\t\tletter-spacing: 3px;\n\t\tcolor: #C4A962;\n\t\tfont-weight: 700;\n\t\tmargin-bottom: 16px;\n\t}\n\t.card-member-name {\n\t\tfont-size: 22px;\n\t\tfont-weight: 800;\n\t\tmargin-bottom: 4px;\n\t\tline-height: 1.2;\n\t}\n\t.card-plan {\n\t\tfont-size: 14px;\n\t\tcolor: #C4A962;\n\t\tfont-weight: 600;\n\t\tmargin-top: 8px;\n\t}\n\t.card-id {\n\t\tposition: absolute;\n\t\ttop: 30px;\n\t\tright: 30px;\n\t\tbackground: rgba(255,255,255,0.12);\n\t\tpadding: 4px 12px;\n\t\tborder-radius: 16px;\n\t\tfont-size: 11px;\n\t\tfont-weight: 600;\n\t\tz-index: 1;\n\t}\n\t.card-gold-bar {\n\t\theight: 4px;\n\t\tbackground: linear-gradient(90deg, #C4A962 0%, #E8D5A0 50%, #C4A962 100%);\n\t}\n\t.card-body {\n\t\tbackground: #FFFFFF;\n\t\tpadding: 24px 30px;\n\t}\n\t.card-info-row {\n\t\tdisplay: flex;\n\t\tjustify-content: space-between;\n\t\tpadding: 8px 0;\n\t\tborder-bottom: 1px solid #F1F5F9;\n\t}\n\t.card-info-row:last-child { border-bottom: none; }\n\t.card-info-label {\n\t\tcolor: #6B7280;\n\t\tfont-size: 12px;\n\t\tfont-weight: 500;\n\t\ttext-transform: uppercase;\n\t\tletter-spacing: 0.5px;\n\t}\n\t.card-info-value {\n\t\tcolor: #1B365D;\n\t\tfont-size: 13px;\n\t\tfont-weight: 700;\n\t}\n\t.card-status {\n\t\tdisplay: inline-block;\n\t\tpadding: 3px 12px;\n\t\tborder-radius: 16px;\n\t\tfont-size: 11px;\n\t\tfont-weight: 700;\n\t\ttext-transform: uppercase;\n\t\tletter-spacing: 0.5px;\n\t}\n\t.card-status.active { background: #D1FAE5; color: #065F46; }\n\t.card-status.expired { background: #FEE2E2; color: #991B1B; }\n\t.card-status.suspended { background: #FEF3C7; color: #92400E; }\n\t.card-status.draft { background: #E5E7EB; color: #374151; }\n\t.card-footer {\n\t\tbackground: #F8FAFC;\n\t\tpadding: 16px 30px;\n\t\ttext-align: center;\n\t\tcolor: #9CA3AF;\n\t\tfont-size: 10px;\n\t\tborder-top: 1px solid #E5E7EB;\n\t}\n</style>\n\n<div class=\"card-container\">\n\t<div class=\"card-top\">\n\t\t<div class=\"card-brand\">&#9670; ARKSpace Member</div>\n\t\t<div class=\"card-id\">{{ doc.name }}</div>\n\t\t<div class=\"card-member-name\">{{ doc.member_name or doc.member }}</div>\n\t\t<div class=\"card-plan\">{{ doc.membership_plan }} &mdash; {{ _(doc.plan_type or '') }}</div>\n\t</div>\n\t<div class=\"card-gold-bar\"></div>\n\t<div class=\"card-body\">\n\t\t<div class=\"card-info-row\">\n\t\t\t<span class=\"card-info-label\">{{ _(\"Status\") }}</span>\n\t\t\t<span>\n\t\t\t\t{% set sc = {'Active': 'active', 'Expired': 'expired', 'Suspended': 'suspended', 'Draft': 'draft'} %}\n\t\t\t\t<span class=\"card-status {{ sc.get(doc.status, 'draft') }}\">{{ _(doc.status) }}</span>\n\t\t\t</span>\n\t\t</div>\n\t\t<div class=\"card-info-row\">\n\t\t\t<span class=\"card-info-label\">{{ _(\"Billing Cycle\") }}</span>\n\t\t\t<span class=\"card-info-value\">{{ _(doc.billing_cycle) }}</span>\n\t\t</div>\n\t\t<div class=\"card-info-row\">\n\t\t\t<span class=\"card-info-label\">{{ _(\"Valid From\") }}</span>\n\t\t\t<span class=\"card-info-value\">{{ doc.get_formatted(\"start_date\") }}</span>\n\t\t</div>\n\t\t<div class=\"card-info-row\">\n\t\t\t<span class=\"card-info-label\">{{ _(\"Valid Until\") }}</span>\n\t\t\t<span class=\"card-info-value\">{{ doc.get_formatted(\"end_date\") }}</span>\n\t\t</div>\n\t\t{% if doc.assigned_space %}\n\t\t<div class=\"card-info-row\">\n\t\t\t<span class=\"card-info-label\">{{ _(\"Assigned Space\") }}</span>\n\t\t\t<span class=\"card-info-value\">{{ doc.assigned_space }}</span>\n\t\t</div>\n\t\t{% endif %}\n\t\t{% if doc.branch %}\n\t\t<div class=\"card-info-row\">\n\t\t\t<span class=\"card-info-label\">{{ _(\"Branch\") }}</span>\n\t\t\t<span class=\"card-info-value\">{{ doc.branch }}</span>\n\t\t</div>\n\t\t{% endif %}\n\t\t{% if doc.initial_credits %}\n\t\t<div class=\"card-info-row\">\n\t\t\t<span class=\"card-info-label\">{{ _(\"Credits\") }}</span>\n\t\t\t<span class=\"card-info-value\" style=\"color: #C4A962;\">{{ doc.initial_credits }}</span>\n\t\t</div>\n\t\t{% endif %}\n\t\t<div class=\"card-info-row\">\n\t\t\t<span class=\"card-info-label\">{{ _(\"Auto Renew\") }}</span>\n\t\t\t<span class=\"card-info-value\">{{ _(\"Yes\") if doc.auto_renew else _(\"No\") }}</span>\n\t\t</div>\n\t</div>\n\t<div class=\"card-footer\">\n\t\t{{ _(\"Present this card at reception\") }} &bull; {{ doc.name }}\n\t</div>\n</div>",
 "idx": 0,
