            "depends_on": "eval:!doc.apply_to_all_spaces"
        },
        {
            "fieldname": "column_break_2",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "apply_to_all_booking_types",
            "fieldtype": "Check",
            "label": "All Booking Types / جميع أنواع الحجز",
            "default": "1"
        },
        {
            "fieldname": "booking_type",
            "fieldtype": "Select",
            "label": "Booking Type / نوع الحجز",
            "options": "\nHourly\nDaily\nMonthly",
