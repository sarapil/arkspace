        {
            "fieldname": "day_of_week",
            "fieldtype": "Select",
            "label": "Day of Week / يوم الأسبوع",
            "options": "\nMonday\nTuesday\nWednesday\nThursday\nFriday\nSaturday\nSunday",
            "depends_on": "eval:doc.condition_type=='Day of Week'"
        },
        {
            "fieldname": "date_start",
            "fieldtype": "Date",
            "label": "Date From / من تاريخ",
            "depends_on": "eval:['Date Range','Seasonal'].includes(doc.condition_type) || doc.rule_type=='Seasonal'"
        },
        {
            "fieldname": "date_end",
            "fieldtype": "Date",
            "label": "Date To / إلى تاريخ",
            "depends_on": "eval:['Date Range','Seasonal'].includes(doc.condition_type) || doc.rule_type=='Seasonal'"
        },
        {
            "fieldname": "min_hours",
            "fieldtype": "Float",
            "label": "Min Hours / الحد الأدنى (ساعات)",
            "depends_on": "eval:doc.condition_type=='Booking Duration' || doc.rule_type=='Long Booking'"
        },
        {
            "fieldname": "max_hours",
            "fieldtype": "Float",
            "label": "Max Hours / الحد الأقصى (ساعات)",
            "depends_on": "eval:doc.condition_type=='Booking Duration' || doc.rule_type=='Long Booking'"
        },
        {
            "fieldname": "member_tier",
            "fieldtype": "Select",
            "label": "Member Tier / مستوى العضوية",
            "options": "\nBronze\nSilver\nGold\nPlatinum\nEnterprise",
            "depends_on": "eval:doc.condition_type=='Member Tier' || doc.rule_type=='Member Tier'"
        },
        {
            "fieldname": "adjustment_section",
