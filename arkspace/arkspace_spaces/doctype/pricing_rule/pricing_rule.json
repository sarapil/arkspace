        },
        {
            "fieldname": "membership_plan",
            "fieldtype": "Link",
            "label": "Membership Plan / خطة العضوية",
            "options": "Membership Plan",
            "depends_on": "eval:doc.rule_type=='Member Tier'"
        },
        {
            "fieldname": "conditions_section",
            "fieldtype": "Section Break",
            "label": "Conditions / الشروط"
        },
        {
            "fieldname": "condition_type",
            "fieldtype": "Select",
            "label": "Condition / الشرط",
